	<ItemGroup>
		<None Include="TemplateClass.cs" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="CommunityToolkit.WinUI.Collections" Version="8.1.240821" />
