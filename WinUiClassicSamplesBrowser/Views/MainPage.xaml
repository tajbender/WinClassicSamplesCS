<Page
    x:Class="ClassicSamplesBrowser.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClassicSamplesBrowser.Views">

    <Grid>

        <!-- Ryder-Style Sidebar -->
        <NavigationView x:Name="NavView"
                        PaneDisplayMode="LeftCompact"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        CompactPaneLength="60"
                        OpenPaneLength="240"
                        SelectionChanged="NavView_SelectionChanged">

            <!-- HeaderBar -->
            <NavigationView.Header>
                <Grid Height="48"
                      Background="{ThemeResource MicaBaseAltFillColorDefaultBrush}">
                    <TextBlock x:Name="HeaderTitle"
                               Text="Home"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Style="{StaticResource TitleTextBlockStyle}" />
                </Grid>
            </NavigationView.Header>

            <!-- Navigation Items -->
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Home" Tag="HomePage" />
                <NavigationViewItem Icon="Library" Content="Samples" Tag="SamplesPage" />
                <NavigationViewItem Icon="Help" Content="About" Tag="AboutPage" />
            </NavigationView.MenuItems>

            <!-- Content -->
            <Frame x:Name="ContentFrame" />

        </NavigationView>

        <!-- Status Bar -->
        <Border Height="28"
                VerticalAlignment="Bottom"
                Background="{ThemeResource MicaBaseAltFillColorDefaultBrush}">
            <TextBlock x:Name="StatusText"
                       Text="Ready."
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Opacity="0.7" />
        </Border>

    </Grid>
</Page>
