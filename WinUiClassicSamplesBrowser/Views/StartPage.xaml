<Page
    x:Class="ClassicSamplesBrowser.Views.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:ClassicSamplesBrowser.Views"
    xmlns:controls="using:ClassicSamplesBrowser.Vanara.Controls">

    <Grid Background="{ThemeResource MicaBaseAltFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="256"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <!-- DirectX Layer -->
            <muxc:SwapChainPanel x:Name="DxHeaderSwapChainPanel"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"/>
            <!-- WinUi on the sea. -->
            <Image Source="/Assets/WinUi-SailBoat-Header-32bit.png"
                   Width="256"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Stretch"
                   Margin="32,0,0,16"
                   Opacity="0.92"
                   IsHitTestVisible="False"/>
            <Border Width="220"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="32,0,0,16">
                <Border.Background>
                    <ImageBrush ImageSource="/Assets/Vanara/Insert-AMIGA-Disk.png"/>
                </Border.Background>
            </Border>
            <!-- Overlay-Text -->
            <StackPanel Padding="32"
                        Spacing="4"
                        VerticalAlignment="Center">
                <TextBlock Text="Vanara API Explorer"
                           FontSize="32"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Browse APIs, Samples, Wrappers, NuGet Versions"
                           FontSize="16"
                           Opacity="0.7"/>
            </StackPanel>
        </Grid>

        <Grid ColumnSpacing="16" RowSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tile 1 -->
            <controls:FeatureTile Grid.Row="0" Grid.Column="0"
                               Icon="&#xE8A5;"
                               Title="API Explorer"
                               Subtitle="Browse types &amp; members"/>

            <!-- Tile 2 -->
            <controls:FeatureTile Grid.Row="0" Grid.Column="1"
                               Icon="&#xE8EF;"
                               Title="Samples Browser"
                               Subtitle="View sample code"/>

            <!-- Tile 3 -->
            <controls:FeatureTile Grid.Row="0" Grid.Column="2"
                               Icon="&#xE71E;"
                               Title="NuGet Versions"
                               Subtitle="Explore releases"/>
        </Grid>

        <!-- TODO: Add
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" -->
        <Grid Grid.Row="1" Width="160" Height="160"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
            <StackPanel Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8A5;" FontSize="32"/>
                <TextBlock Text="API Explorer" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock FontSize="12" Opacity="0.6" Text="Browse types &amp; members" />
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Padding="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: ACTIONS -->
            <StackPanel Spacing="20">
                <!-- Version Selector -->
                <StackPanel>
                    <TextBlock Text="Vanara Version"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="VersionSelector"
                              PlaceholderText="Loading versions..."
                              Width="260"/>
                </StackPanel>

                <Button Content="Load Assemblies"
                        Click="LoadAssemblies_Click"
                        Width="260"/>

                <Button Content="Open API Explorer"
                        Click="OpenExplorer_Click"
                        Width="260"/>

                <Button Content="Open Samples Browser"
                        Click="OpenSamples_Click"
                        Width="260"/>

                <Button Content="Project Builder (coming soon)"
                        Width="260"
                        IsEnabled="False"/>
            </StackPanel>

            <!-- RIGHT: INFO PANEL -->
            <StackPanel Grid.Column="1" Padding="32" Spacing="12">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="What this tool does."/>
                <TextBlock Opacity="0.8" Text="This Explorer lets you browse Vanara APIs, inspect types, view samples, explore NuGet versions, and understand wrapper relationships. It is powered by reflection, NuGet metadata, and the Vanara test suite." TextWrapping="Wrap"/>
                <TextBlock FontWeight="SemiBold" Margin="0,12,0,0" Text="Core Features"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="• API Tree (Namespaces → Types → Members)"/>
                    <TextBlock Text="• NuGet Version Selector"/>
                    <TextBlock Text="• Sample Mapping (Unit Tests → API)"/>
                    <TextBlock Text="• Wrapper Detection (IShellItem → ShellItem)"/>
                    <TextBlock Text="• Reflection‑based Metadata"/>
                    <TextBlock Text="• TaskScheduler Integration"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
