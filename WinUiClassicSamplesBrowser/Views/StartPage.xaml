<Page
    x:Class="ClassicSamplesBrowser.Views.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:ClassicSamplesBrowser.Views"
    xmlns:controls="using:ClassicSamplesBrowser.Vanara.Controls">

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="256"/>
            <RowDefinition Height="256"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" x:Name="DirectXHeaderGrid" MaxHeight="256">
            <Grid.ColumnDefinitions>
                <ColumnDefinition>Auto</ColumnDefinition>
                <ColumnDefinition>Auto</ColumnDefinition>
                <ColumnDefinition>*</ColumnDefinition>
            </Grid.ColumnDefinitions>
            <!-- DirectX Background Layer -->
            <muxc:SwapChainPanel x:Name="DxHeaderSwapChainPanel" Grid.Column="0" Grid.ColumnSpan="3"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            <!-- Overlay: WinUi on the sea. -->
            <Image x:Name="VanaraLogo" Grid.Column="0" MaxHeight="64" Source="/Assets/Vanara/Vanara-64px.png" VerticalAlignment="Center"/>
            <!-- Overlay-Text -->
            <StackPanel Grid.Column ="1" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock FontSize="32" FontWeight="SemiBold" Text="Vanara API Explorer"/>
                <TextBlock FontSize="16" Opacity="0.7" Text="Browse APIs, Samples, Wrappers, NuGet Versions"/>
            </StackPanel>
            <Image x:Name="WinUiSailBoatHeader"
                   Grid.Column="2" 
                   VerticalAlignment="Stretch"
                   Source="/Assets/WinUi-SailBoat-Header-32bit.png"
                   Opacity="0.92"
                   Margin="32,0,0,16"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Right"/>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="16" RowSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <controls:FeatureTile Grid.Column="0" Grid.Row="0" 
                                  Icon="&#xE71E;"
                                  Title="NuGet Versions"
                                  Subtitle="Explore releases"/>
            <controls:FeatureTile Grid.Column="1" Grid.Row="0" 
                                  Icon="&#xE8A5;"
                                  Title="GitHub Repository"
                                  Subtitle="Browse types &amp; members"/>
            <controls:FeatureTile Grid.Row="0" Grid.Column="2"
                                  Icon="&#xE8A5;"
                                  Title="API Explorer"
                                  Subtitle="Browse types &amp; members"/>
            <controls:FeatureTile Grid.Row="0" Grid.Column="3"
                                  Icon="&#xE8EF;"
                                  Title="Samples Browser"
                                  Subtitle="View sample code"/>
        </Grid>

        <!--  TODO: Add
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" -->

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Padding="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: ACTIONS -->
            <StackPanel Spacing="20">
                <!-- Version Selector -->
                <StackPanel>
                    <TextBlock Text="Vanara Version"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="VersionSelector"
                              PlaceholderText="Loading versions..."
                              Width="260"/>
                </StackPanel>

                <Button Content="Load Assemblies"
                        Click="LoadAssemblies_Click"
                        Width="260"/>

                <Button Content="Open API Explorer"
                        Click="OpenExplorer_Click"
                        Width="260"/>

                <Button Content="Open Samples Browser"
                        Click="OpenSamples_Click"
                        Width="260"/>

                <Button Content="Project Builder (coming soon)"
                        Width="260"
                        IsEnabled="False"/>
            </StackPanel>

            <!-- RIGHT: INFO PANEL -->
            <StackPanel Grid.Column="1" Padding="32" Spacing="12">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="What this tool does."/>
                <TextBlock Opacity="0.8" Text="This Explorer lets you browse Vanara APIs, inspect types, view samples, explore NuGet versions, and understand wrapper relationships. It is powered by reflection, NuGet metadata, and the Vanara test suite." TextWrapping="Wrap"/>
                <TextBlock FontWeight="SemiBold" Margin="0,12,0,0" Text="Core Features"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="• API Tree (Namespaces → Types → Members)"/>
                    <TextBlock Text="• NuGet Version Selector"/>
                    <TextBlock Text="• Sample Mapping (Unit Tests → API)"/>
                    <TextBlock Text="• Wrapper Detection (IShellItem → ShellItem)"/>
                    <TextBlock Text="• Reflection‑based Metadata"/>
                    <TextBlock Text="• TaskScheduler Integration"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
