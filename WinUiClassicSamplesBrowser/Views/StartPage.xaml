<Page
    x:Class="ClassicSamplesBrowser.Views.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClassicSamplesBrowser.Views">

    <Grid Background="{ThemeResource MicaBaseAltFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Padding="32" Spacing="4">
            <TextBlock Text="Vanara API Explorer"
                       FontSize="32"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Browse APIs, Samples, Wrappers, NuGet Versions"
                       FontSize="16"
                       Opacity="0.7"/>
        </StackPanel>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Padding="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: ACTIONS -->
            <StackPanel Spacing="20">

                <!-- Version Selector -->
                <StackPanel>
                    <TextBlock Text="Vanara Version"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="VersionSelector"
                              PlaceholderText="Loading versions..."
                              Width="260"/>
                </StackPanel>

                <!-- Load Assemblies -->
                <Button Content="Load Assemblies"
                        Click="LoadAssemblies_Click"
                        Width="260"/>

                <!-- Open API Explorer -->
                <Button Content="Open API Explorer"
                        Click="OpenExplorer_Click"
                        Width="260"/>

                <!-- Open Samples Browser -->
                <Button Content="Open Samples Browser"
                        Click="OpenSamples_Click"
                        Width="260"/>

                <!-- Project Builder -->
                <Button Content="Project Builder (coming soon)"
                        Width="260"
                        IsEnabled="False"/>
            </StackPanel>

            <!-- RIGHT: INFO PANEL -->
            <StackPanel Grid.Column="1" Padding="32" Spacing="12">
                <TextBlock Text="What this tool does"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <TextBlock Text="This Explorer lets you browse Vanara APIs, inspect types, view samples, explore NuGet versions, and understand wrapper relationships. It is powered by reflection, NuGet metadata, and the Vanara test suite."
                           TextWrapping="Wrap"
                           Opacity="0.8"/>

                <TextBlock Text="Core Features"
                           FontWeight="SemiBold"
                           Margin="0,12,0,0"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="• API Tree (Namespaces → Types → Members)"/>
                    <TextBlock Text="• NuGet Version Selector"/>
                    <TextBlock Text="• Sample Mapping (Unit Tests → API)"/>
                    <TextBlock Text="• Wrapper Detection (IShellItem → ShellItem)"/>
                    <TextBlock Text="• Reflection‑based Metadata"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
