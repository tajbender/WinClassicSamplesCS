<Page
    x:Class="ClassicSamplesBrowser.Views.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:local="using:ClassicSamplesBrowser.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="42,*,42" VerticalAlignment="Top">
        <Image Grid.Row="0" Height="256" Source="/Assets/Vanara/WinUi%20Sailing%20in%20the%20Seas%20of%20Cheese.png"></Image>
        <ListView Grid.Row="1" Height="512"></ListView>
        <Border Grid.Row="2" Background="#22000000" Height="28" VerticalAlignment="Bottom" Padding="12,0">
            <StackPanel Orientation="Horizontal">
                <Image Grid.Row="0" Height="256" Source="/Assets/Vanara/WinUi%20Sailing%20in%20the%20Seas%20of%20Cheese.png"></Image>
                <TextBlock Text="Ready." Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
