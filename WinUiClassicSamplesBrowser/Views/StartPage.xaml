<Page
    x:Class="ClassicSamplesBrowser.Views.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:local="using:ClassicSamplesBrowser.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Ready." Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
        <Border Grid.Row="1" Background="{ThemeResource SystemBaseMediumColor}" Height="180" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <muxc:TabView x:Name="MainTabs" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" TabWidthMode="SizeToContent">
                <muxc:TabViewItem Header="Explorer">
                    <TextBlock Text="Explorer Content…" />
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="API">
                    <TextBlock Text="API Content…" />
                </muxc:TabViewItem>
            </muxc:TabView>
        </Border>
        <Border Grid.Row="2" Background="#22000000" Height="28" VerticalAlignment="Bottom" Padding="12,0">
            <TextBlock Text="Ready." Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Page>
